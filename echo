#!/usr/bin/env bash

BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICES=(tts:src/app.py:47100 llm:src/app.py:47101 stt:src/app.py:47102 avatar:src/server.py:47103 memory:src/app.py:47104 panel:serve.py:47105)

start() {
    if [ ! -f "$BASE/.pids/.setup" ]; then
        echo "run ./echo setup first."
        exit 1
    fi
    mkdir -p "$BASE/.pids"
    for entry in "${SERVICES[@]}"; do
        IFS=':' read -r name script port <<< "$entry"
        cd "$BASE/services/$name"
        uv run python "$script" >> "$BASE/.pids/$name.log" 2>&1 &
        echo $! > "$BASE/.pids/$name.pid"
        printf '  %-7s http://localhost:%s\n' "$name" "$port"
    done
    echo "started. logs: ./echo logs"
}

stop() {
    for entry in "${SERVICES[@]}"; do
        IFS=':' read -r name script port <<< "$entry"
        fuser -k "$port/tcp" >/dev/null 2>&1
    done
    rm -f "$BASE/.pids"/*.pid
    echo "stopped."
}

setup() {
    git submodule update --init --recursive
    uv sync
    for entry in "${SERVICES[@]}"; do
        IFS=':' read -r name script port <<< "$entry"
        if [ -f "$BASE/services/$name/src/setup.py" ]; then
            ( cd "$BASE/services/$name/src" && python3 setup.py --no-venv )
        fi
    done
    mkdir -p "$BASE/.pids"
    touch "$BASE/.pids/.setup"
}

logs() { tail -f "$BASE/.pids"/*.log; }

clean() {
    # never delete from the filesystem root: cant be too cautious
    if [ -z "$BASE" ] || [ "$BASE" = "/" ]; then
        echo "refusing to run with BASE='$BASE'"
        exit 1
    fi
    stop
    rm -rf "$BASE/.venv" "$BASE/.pids"
    for entry in "${SERVICES[@]}"; do
        IFS=':' read -r name script port <<< "$entry"
        rm -rf "$BASE/services/$name/src/private" "$BASE/services/$name/src/$name-venv"
    done
    rm -rf "$BASE/services/memory/data"
    local caches=(__pycache__ .pytest_cache .mypy_cache .ruff_cache "*.egg-info")
    for pat in "${caches[@]}"; do
        find "$BASE/services" -type d -name "$pat" -exec rm -rf {} + 2>/dev/null
    done
    echo "cleaned."
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    setup)   setup ;;
    clean)   clean ;;
    logs)    logs ;;
    *)       echo "usage: ./echo start|stop|restart|setup|clean|logs" ;;
esac
